# Database
DATABASE_URL="postgresql://user:password@localhost:5432/family-picnic"

# Dev auth bypass (set DEV_AUTH_ENABLED=true to enable username/password login)
DEV_AUTH_ENABLED=false
DEV_AUTH_USERNAME=admin
DEV_AUTH_PASSWORD=change-me

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-string"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Twilio (SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# SendGrid (Email)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@family-picnic.example.com"

# S3-compatible Storage
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="family-picnic"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""

# PhotoPrism
PHOTOPRISM_URL="http://photoprism:2342"
PHOTOPRISM_API_KEY=""

# Observability
LOG_LEVEL="info"
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
