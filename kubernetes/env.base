# Next.js public environment variables (non-sensitive)
NEXTAUTH_URL=https://family.example.com
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://family.example.com

# PostgreSQL connection (reference to secret)
DATABASE_URL=postgresql://postgres:password@postgres.family-picnic.svc.cluster.local:5432/familypicnic?schema=public

# S3 Storage
S3_BUCKET=family-picnic-photos
S3_REGION=us-east-1
S3_ENDPOINT=

# PhotoPrism
PHOTOPRISM_URL=http://photoprism.family-picnic.svc.cluster.local:8080
